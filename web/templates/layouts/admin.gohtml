{{define "admin"}}<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{block "title" .}}Administration — Épure{{end}}</title>
<meta name="robots" content="noindex, nofollow">
<link rel="stylesheet" href="/static/css/tokens.css">
<link rel="stylesheet" href="/static/css/base.css">
<link rel="stylesheet" href="/static/css/components.css">
<link rel="stylesheet" href="/static/css/utilities.css">
<link rel="stylesheet" href="/static/css/admin.css">
<script src="/static/vendor/unpoly.min.js"></script>
<link rel="stylesheet" href="/static/vendor/unpoly.min.css">
</head>
<body>

<a href="#main" class="skip-link">Aller au contenu</a>

<div class="admin-layout" data-component="admin-layout">

  <!-- SIDEBAR -->
  <aside class="admin-sidebar" data-component="admin-sidebar" id="admin-sidebar">
    <div class="admin-sidebar__logo">
      <a href="/admin" class="admin-sidebar__logo-text" up-follow>Épure</a>
    </div>

    <nav class="admin-sidebar__nav" aria-label="Navigation administration">
      <div class="admin-sidebar__section-title">Principal</div>
      <a href="/admin" class="admin-sidebar__link{{if eq .ActivePage "dashboard"}} admin-sidebar__link--active{{end}}" up-follow>
        <svg class="admin-sidebar__link-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="7" height="7" rx="1"/><rect x="11" y="2" width="7" height="7" rx="1"/><rect x="2" y="11" width="7" height="7" rx="1"/><rect x="11" y="11" width="7" height="7" rx="1"/></svg>
        <span class="admin-sidebar__link-label">Tableau de bord</span>
      </a>
      <a href="/admin/orders" class="admin-sidebar__link{{if eq .ActivePage "orders"}} admin-sidebar__link--active{{end}}" up-follow>
        <svg class="admin-sidebar__link-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h16l-1.5 9H3.5L2 3z"/><circle cx="7" cy="17" r="1.5"/><circle cx="14" cy="17" r="1.5"/></svg>
        <span class="admin-sidebar__link-label">Commandes</span>
      </a>
      <a href="/admin/products" class="admin-sidebar__link{{if eq .ActivePage "products"}} admin-sidebar__link--active{{end}}" up-follow>
        <svg class="admin-sidebar__link-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="16" height="16" rx="2"/><circle cx="7" cy="7" r="1.5"/><path d="M2 12l4-4 3 3 5-5"/></svg>
        <span class="admin-sidebar__link-label">Produits</span>
      </a>
      <a href="/admin/customers" class="admin-sidebar__link{{if eq .ActivePage "customers"}} admin-sidebar__link--active{{end}}" up-follow>
        <svg class="admin-sidebar__link-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="7" r="3"/><path d="M3 18c0-3.3 3.1-6 7-6s7 2.7 7 6"/></svg>
        <span class="admin-sidebar__link-label">Clients</span>
      </a>

      <div class="admin-sidebar__section-title">Catalogue</div>
      <a href="/admin/categories" class="admin-sidebar__link{{if eq .ActivePage "categories"}} admin-sidebar__link--active{{end}}" up-follow>
        <svg class="admin-sidebar__link-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h6v6H3V3zM12 11h5v6h-5v-6z"/><path d="M3 14l4-5 3 4 5-6"/></svg>
        <span class="admin-sidebar__link-label">Catégories</span>
      </a>
      <a href="/admin/discounts" class="admin-sidebar__link{{if eq .ActivePage "discounts"}} admin-sidebar__link--active{{end}}" up-follow>
        <svg class="admin-sidebar__link-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="10" r="8"/><path d="M10 6v8M7 10h6"/></svg>
        <span class="admin-sidebar__link-label">Réductions</span>
      </a>

      <div class="admin-sidebar__section-title">Configuration</div>
      <a href="/admin/settings" class="admin-sidebar__link{{if eq .ActivePage "settings"}} admin-sidebar__link--active{{end}}" up-follow>
        <svg class="admin-sidebar__link-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="10" r="3"/><path d="M10 1v3M10 16v3M1 10h3M16 10h3M3.5 3.5l2.1 2.1M14.4 14.4l2.1 2.1M3.5 16.5l2.1-2.1M14.4 5.6l2.1-2.1"/></svg>
        <span class="admin-sidebar__link-label">Paramètres</span>
      </a>
    </nav>

    <button class="admin-sidebar__toggle" data-action="sidebar-toggle" aria-label="Réduire la barre latérale">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8h10M6 4l4 4-4 4"/></svg>
    </button>
  </aside>

  <!-- MAIN AREA -->
  <div class="admin-main">

    <!-- TOPBAR -->
    <header class="admin-topbar" data-component="admin-topbar">
      <div class="admin-topbar__left">
        <div class="admin-topbar__search" data-component="search-filter">
          <svg class="admin-topbar__search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="7" cy="7" r="5"/><path d="M11 11l3 3"/></svg>
          <input type="search" class="admin-topbar__search-input" placeholder="Rechercher…" data-search-target="" data-debounce="200" aria-label="Rechercher">
        </div>
      </div>
      <div class="admin-topbar__right">
        <button class="admin-topbar__notification" aria-label="Notifications" data-component="notification-count" data-count="{{.NotificationCount}}" data-max="99">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 2c-2.8 0-5 2.2-5 5v2l-2 3h14l-2-3V7c0-2.8-2.2-5-5-5z"/><path d="M7 17a3 3 0 006 0"/></svg>
          {{if .NotificationCount}}<span class="admin-topbar__notif-badge" aria-label="{{.NotificationCount}} notifications">{{.NotificationCount}}</span>{{end}}
        </button>
        <div class="dropdown" data-component="dropdown">
          <button class="admin-topbar__avatar" data-dropdown-trigger aria-label="Menu utilisateur">{{.AdminInitials}}</button>
          <div class="dropdown__menu" data-dropdown-menu>
            <a href="/account" class="dropdown__item" up-follow>Mon profil</a>
            <a href="/admin/settings" class="dropdown__item" up-follow>Paramètres</a>
            <div class="dropdown__divider"></div>
            <a href="/admin/logout" class="dropdown__item dropdown__item--danger" up-method="post" up-follow>Déconnexion</a>
          </div>
        </div>
      </div>
    </header>

    <!-- CONTENT -->
    <main id="main" class="admin-content">
{{block "content" .}}{{end}}
    </main>

  </div><!-- /admin-main -->
</div><!-- /admin-layout -->

<script src="/static/js/ui.js"></script>
<script src="/static/js/admin.js"></script>
</body>
</html>
{{end}}
