{{define "header"}}
<header class="shop-header" role="banner">
  <div class="container">
    <div class="shop-header__top">
      <button class="mobile-menu-toggle" data-action="open-mobile-menu" aria-label="Menu" aria-expanded="false">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 6h16M3 11h16M3 16h16"/>
        </svg>
      </button>

      <a href="/" class="shop-header__logo" aria-label="Épure — Accueil" up-follow>Épure</a>

      <div class="shop-header__search" role="search">
        <svg class="shop-header__search-icon" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="8.5" cy="8.5" r="6"/><path d="M13 13l5 5"/>
        </svg>
        <form action="/search" method="GET" up-target="main" up-submit>
          <input type="search" class="shop-header__search-input" placeholder="Rechercher un produit..." aria-label="Rechercher un produit" name="q" autocomplete="off" value="{{.Query}}">
        </form>
      </div>

      <nav class="shop-header__actions" aria-label="Actions">
        <a href="/favorites" class="shop-header__action" aria-label="Favoris" data-tooltip="Favoris" up-follow>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 17.5l-1.45-1.32C3.4 11.36 1.5 9.57 1.5 7.28 1.5 4.77 3.43 2.5 6 2.5c1.42 0 2.78.7 3.65 1.78L10 4.7l.35-.42C11.22 3.2 12.58 2.5 14 2.5c2.57 0 4.5 2.27 4.5 4.78 0 2.29-1.9 4.08-7.05 8.9L10 17.5z"/></svg>
        </a>
        <a href="/account" class="shop-header__action" aria-label="Compte" data-tooltip="Mon compte" up-follow>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="7" r="4"/><path d="M3 18c0-3.5 3.1-6.5 7-6.5s7 3 7 6.5"/></svg>
        </a>
        <button class="shop-header__action" aria-label="Panier" data-action="open-cart" data-tooltip="Panier">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h2l.5 2m0 0L7 14h8l2-9H5.5z"/><circle cx="8.5" cy="17.5" r="1.5"/><circle cx="15.5" cy="17.5" r="1.5"/></svg>
          <span class="shop-header__badge" data-component="cart-count" aria-label="{{.CartCount}} article{{if ne .CartCount 1}}s{{end}}">{{.CartCount}}</span>
        </button>
      </nav>
    </div>

    <nav class="shop-nav" aria-label="Navigation principale">
      <ul class="shop-nav__list">
        {{range .Categories}}
        <li><a href="/c/{{.Slug}}" class="shop-nav__link{{if eq $.ActiveCategory .Slug}} shop-nav__link--active{{end}}" up-follow>{{.Name}}</a></li>
        {{end}}
      </ul>
    </nav>
  </div>
</header>
{{end}}
