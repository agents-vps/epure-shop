{{define "product-grid"}}
<div class="grid-{{if .Columns}}{{.Columns}}{{else}}3{{end}}">
  {{range .Products}}
  <article class="product-card" data-component="product-card">
    <div class="product-card__image-wrapper">
      <div class="product-card__image u-flex u-items-center u-justify-center u-text-sm u-text-subtle u-aspect-3-4" style="background:oklch(85% 0.04 245)">
        {{if .ImageURL}}<img src="{{.ImageURL}}" alt="{{.Name}}" class="u-w-full u-h-full u-object-cover">{{else}}<span class="u-text-subtle">{{.Name}}</span>{{end}}
      </div>
      <div class="product-card__actions">
        <button class="product-card__action-btn" aria-label="Ajouter aux favoris" data-component="favorite-toggle" data-product-id="{{.ID}}" data-state="inactive">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 17.5l-1.45-1.32C3.4 11.36 1.5 9.57 1.5 7.28 1.5 4.77 3.43 2.5 6 2.5c1.42 0 2.78.7 3.65 1.78L10 4.7l.35-.42C11.22 3.2 12.58 2.5 14 2.5c2.57 0 4.5 2.27 4.5 4.78 0 2.29-1.9 4.08-7.05 8.9L10 17.5z"/></svg>
        </button>
      </div>
    </div>
    <a href="/product/{{.Slug}}" class="product-card__body" up-follow>
      <span class="product-card__category">{{.CategoryName}}</span>
      <h3 class="product-card__title">{{.Name}}</h3>
      <div class="product-card__rating">
        <span class="product-card__stars" aria-label="{{printf "%.1f" .Rating}} sur 5 étoiles">★★★★★</span>
        <span>{{printf "%.1f" .Rating}}</span>
        <span>({{.ReviewCount}})</span>
      </div>
      <div class="product-card__price">
        {{money .Price}}
        {{if .ComparePrice}}<span class="product-card__price--old">{{money .ComparePrice}}</span>{{end}}
      </div>
    </a>
  </article>
  {{end}}
</div>
{{end}}
