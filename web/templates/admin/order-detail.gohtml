{{define "title"}}Commande #{{.Order.Ref}} — Administration Épure{{end}}
{{define "content"}}

  <div class="admin-content__header">
    <a href="/admin/orders" class="btn btn--ghost btn--sm" up-follow>&larr; Retour aux commandes</a>
    <h1 class="admin-content__title">Commande #{{.Order.Ref}}</h1>
    <div class="admin-content__actions">
      <span class="badge badge--{{.Order.StatusBadge}} u-text-md">{{.Order.Status}}</span>
    </div>
  </div>

  <div class="u-grid u-gap-6 u-grid-cols-2">
    <div class="u-bg-card u-radius-md" style="border:1px solid var(--color-border); padding:var(--space-4)">
      <h2 class="u-mb-3 u-text-sm u-fw-semibold u-text-muted">Informations client</h2>
      <p class="u-fw-medium">{{.Order.CustomerName}}</p>
      <p class="u-text-sm u-text-muted">{{.Order.Email}}</p>
    </div>
    <div class="u-bg-card u-radius-md" style="border:1px solid var(--color-border); padding:var(--space-4)">
      <h2 class="u-mb-3 u-text-sm u-fw-semibold u-text-muted">Adresse de livraison</h2>
      <p class="u-text-sm">{{.Order.ShippingAddress}}</p>
    </div>
  </div>

  <div class="table-wrapper u-mt-6">
    <table class="table">
      <thead>
        <tr><th>Article</th><th>Quantité</th><th>Prix unitaire</th><th>Total</th></tr>
      </thead>
      <tbody>
        {{range .Order.Items}}
        <tr>
          <td>{{.Name}}</td>
          <td>{{.Quantity}}</td>
          <td>{{money .UnitPrice}}</td>
          <td class="u-fw-medium">{{money (multiply .UnitPrice .Quantity)}}</td>
        </tr>
        {{end}}
      </tbody>
      <tfoot>
        <tr><td class="u-text-right u-fw-semibold" colspan="3">Sous-total</td><td>{{money .Order.Subtotal}}</td></tr>
        <tr><td class="u-text-right u-fw-semibold" colspan="3">Livraison</td><td>{{money .Order.ShippingCost}}</td></tr>
        {{if .Order.DiscountAmount}}<tr><td class="u-text-right u-fw-semibold" colspan="3">Réduction</td><td class="u-text-error">−{{money .Order.DiscountAmount}}</td></tr>{{end}}
        <tr><td class="u-text-right u-fw-bold" colspan="3">Total</td><td class="u-fw-bold">{{money .Order.Total}}</td></tr>
      </tfoot>
    </table>
  </div>

  <div class="u-mt-6 u-flex u-gap-3">
    <form action="/admin/orders/{{.Order.ID}}/status" method="POST" up-submit class="u-flex u-gap-3">
      <select name="status" class="form-select">
        <option value="">Changer le statut</option>
        <option value="confirmed"{{if eq .Order.Status "confirmed"}} selected{{end}}>Confirmée</option>
        <option value="shipped"{{if eq .Order.Status "shipped"}} selected{{end}}>Expédiée</option>
        <option value="delivered"{{if eq .Order.Status "delivered"}} selected{{end}}>Livrée</option>
        <option value="cancelled"{{if eq .Order.Status "cancelled"}} selected{{end}}>Annulée</option>
      </select>
      <button type="submit" class="btn btn--primary btn--sm">Mettre à jour</button>
    </form>
  </div>

{{end}}
