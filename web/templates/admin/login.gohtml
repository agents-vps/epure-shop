{{define "title"}}Connexion — Administration Épure{{end}}
{{define "content"}}
  <div class="admin-login" data-component="admin-login">
    <div class="admin-login__card">
      <div class="admin-login__logo">Épure</div>
      <h1 class="admin-login__title">Administration</h1>
      <p class="admin-login__subtitle">Connectez-vous pour gérer votre boutique</p>

      {{if .Error}}
      <div class="u-flex u-items-center u-gap-2 u-mb-5 u-bg-error-light u-radius-sm" style="padding:var(--space-3)">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="var(--color-error)" stroke-width="1.5"><circle cx="10" cy="10" r="9"/><path d="M7 7l6 6M13 7l-6 6"/></svg>
        <p class="u-text-sm u-fw-medium u-text-error">{{.Error}}</p>
      </div>
      {{end}}

      <form action="/admin/login" method="POST" up-submit autocomplete="on" novalidate>
        <div class="form-group u-mb-5">
          <label class="form-label" for="login-email">Email</label>
          <input type="email" id="login-email" name="email" class="form-input" placeholder="vous@epure-boutique.fr" autocomplete="email" required value="{{.Email}}">
        </div>

        <div class="form-group u-mb-3">
          <label class="form-label" for="login-password">Mot de passe</label>
          <input type="password" id="login-password" name="password" class="form-input" placeholder="••••••••" autocomplete="current-password" required>
        </div>

        <div class="u-flex u-items-center u-justify-between u-mb-6">
          <label class="checkbox">
            <input type="checkbox" class="checkbox__input" name="remember" id="login-remember">
            <span>Se souvenir de moi</span>
          </label>
          <a class="u-text-sm" href="/admin/forgot-password" up-follow>Mot de passe oublié ?</a>
        </div>

        <button type="submit" class="btn btn--primary u-w-full">Se connecter</button>
      </form>
    </div>
  </div>
{{end}}
