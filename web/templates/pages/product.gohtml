{{define "title"}}{{.Product.Name}} — Épure{{end}}
{{define "description"}}{{.Product.Description}}{{end}}
{{define "content"}}
  <div class="container">

    {{template "breadcrumb" dict "Breadcrumbs" .Breadcrumbs}}

    <div data-component="product-detail">
      {{if .Product}}
      <div class="product-detail">

        <!-- GALLERY -->
        <div data-component="product-gallery">
          <div class="product-gallery__main">
            {{if .Product.ImageURL}}
            <img class="u-w-full u-h-full u-object-cover" data-gallery-main src="{{.Product.ImageURL}}" alt="{{.Product.Name}}">
            {{else}}
            <div class="u-flex u-items-center u-justify-center u-w-full u-h-full u-text-sm u-text-subtle" style="background:linear-gradient(135deg, var(--color-accent-light), oklch(92% 0.06 245))">{{.Product.Name}}</div>
            {{end}}
          </div>
          <div class="product-gallery__thumbs">
          </div>
        </div>

        <!-- PRODUCT INFO -->
        <div>
          <p class="product-info__category">{{.Product.CategoryName}}</p>
          <h1 class="product-info__title">{{.Product.Name}}</h1>

          <div class="product-info__rating">
            <span class="product-info__stars" aria-label="{{printf "%.1f" .Product.Rating}} sur 5 étoiles">★★★★★</span>
            <span>{{printf "%.1f" .Product.Rating}}</span>
            <a class="u-text-muted" href="#reviews" up-follow>({{.Product.ReviewCount}} avis)</a>
          </div>

          <div class="product-info__price">
            {{money .Product.Price}}
            {{if .Product.ComparePrice}}<span class="product-info__price-old">{{money .Product.ComparePrice}}</span>{{end}}
          </div>

          <p class="u-mb-6 u-text-muted u-leading-relaxed">{{.Product.Description}}</p>

          <!-- Actions -->
          <div class="product-actions">
            <div class="product-actions__row">
              <div class="stepper" data-component="stepper">
                <button class="stepper__btn" aria-label="Réduire la quantité">−</button>
                <input type="number" class="stepper__input" value="1" min="1" max="99" aria-label="Quantité">
                <button class="stepper__btn" aria-label="Augmenter la quantité">+</button>
              </div>
              <button class="btn btn--primary btn--lg u-flex-1" data-component="add-to-cart" data-product-id="{{.Product.ID}}" data-product-name="{{.Product.Name}}" data-product-price="{{.Product.Price.Cents}}">
                Ajouter au panier
              </button>
            </div>
            <div class="product-actions__row">
              <button class="btn btn--secondary u-flex-1" data-component="favorite-toggle" data-product-id="{{.Product.ID}}" data-state="inactive">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M10 17.5l-1.45-1.32C3.4 11.36 1.5 9.57 1.5 7.28 1.5 4.77 3.43 2.5 6 2.5c1.42 0 2.78.7 3.65 1.78L10 4.7l.35-.42C11.22 3.2 12.58 2.5 14 2.5c2.57 0 4.5 2.27 4.5 4.78 0 2.29-1.9 4.08-7.05 8.9L10 17.5z"/></svg>
                Ajouter aux favoris
              </button>
            </div>
          </div>

          <!-- Reassurance -->
          <div class="u-flex u-flex-col u-gap-2 u-mt-6 u-pt-6 u-text-sm u-text-muted u-border-t">
            <div class="u-flex u-items-center u-gap-2">
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="var(--color-success)" stroke-width="2" aria-hidden="true"><path d="M5 10l3 3 7-7"/></svg>
              Livraison neutre en carbone — 3-5 jours
            </div>
            <div class="u-flex u-items-center u-gap-2">
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="var(--color-success)" stroke-width="2" aria-hidden="true"><path d="M5 10l3 3 7-7"/></svg>
              Retours gratuits sous 30 jours
            </div>
            <div class="u-flex u-items-center u-gap-2">
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="var(--color-success)" stroke-width="2" aria-hidden="true"><path d="M5 10l3 3 7-7"/></svg>
              Pièce unique fabriquée en France
            </div>
          </div>
        </div>
      </div>
      {{else}}
      {{template "empty-state" dict "Title" "Produit indisponible" "Text" "Ce produit n'a pas pu être chargé. Il a peut-être été retiré ou est temporairement inaccessible." "ActionURL" "/category" "ActionLabel" "Retour aux produits"}}
      {{end}}
    </div>

    <!-- SIMILAR PRODUCTS -->
    {{if .SimilarProducts}}
    <section class="section">
      <div class="section__header">
        <h2 class="section__title">Vous aimerez aussi</h2>
      </div>
      <div class="grid-4">
        {{range .SimilarProducts}}
        {{template "product-card" .}}
        {{end}}
      </div>
    </section>
    {{end}}
  </div>
{{end}}
