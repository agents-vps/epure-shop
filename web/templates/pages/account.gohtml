{{define "title"}}Mon compte — Épure{{end}}
{{define "content"}}
  <div class="container">

    {{template "breadcrumb" dict "Breadcrumbs" .Breadcrumbs}}

    <h1>Mon compte</h1>

    <div class="account-layout">

      <!-- SIDEBAR NAV -->
      <aside>
        <nav class="account-nav" aria-label="Navigation du compte" data-component="account-tabs">
          <a href="/account?tab=profile" class="account-nav__link{{if eq .ActiveTab "profile"}} account-nav__link--active{{end}}" up-follow up-target=".account-layout">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="7" r="4"/><path d="M3 18c0-4.4 3.1-7 7-7s7 2.6 7 7"/></svg>
            Profil
          </a>
          <a href="/account?tab=orders" class="account-nav__link{{if eq .ActiveTab "orders"}} account-nav__link--active{{end}}" up-follow up-target=".account-layout">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="2" width="14" height="16" rx="2"/><path d="M3 6h14M7 2v4M13 2v4"/></svg>
            Commandes
          </a>
          <a href="/account?tab=addresses" class="account-nav__link{{if eq .ActiveTab "addresses"}} account-nav__link--active{{end}}" up-follow up-target=".account-layout">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 2C6.7 2 4 4.7 4 8c0 5 6 10 6 10s6-5 6-10c0-3.3-2.7-6-6-6z"/><circle cx="10" cy="8" r="1.5"/></svg>
            Adresses
          </a>
          <a href="/account?tab=favorites" class="account-nav__link{{if eq .ActiveTab "favorites"}} account-nav__link--active{{end}}" up-follow up-target=".account-layout">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 17.5l-1.45-1.32C3.4 11.36 1.5 9.57 1.5 7.28 1.5 4.77 3.43 2.5 6 2.5c1.42 0 2.78.7 3.65 1.78L10 4.7l.35-.42C11.22 3.2 12.58 2.5 14 2.5c2.57 0 4.5 2.27 4.5 4.78 0 2.29-1.9 4.08-7.05 8.9L10 17.5z"/></svg>
            Favoris
          </a>
          <hr class="u-border-t u-p-4">
          <form action="/logout" method="POST" up-submit>
            <button type="submit" class="account-nav__link u-text-error u-w-full u-text-left" style="background:none;border:none;cursor:pointer;font:inherit;">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 13l-4-4 4-4M3 9h12M16 3v2M16 17v-2"/></svg>
              Déconnexion
            </button>
          </form>
        </nav>
      </aside>

      <!-- CONTENT AREA -->
      <div data-component="account-content">
        {{if eq .ActiveTab "profile"}}
        <!-- PROFILE TAB -->
        <section>
          <h2 class="u-mb-6 u-text-2xl">Informations personnelles</h2>
          <form class="u-max-w-520" action="/account" method="POST" up-submit novalidate>
            <div class="u-grid u-gap-4 u-grid-cols-2 u-mb-4">
              <div class="form-group">
                <label class="form-label" for="account-firstname">Prénom</label>
                <input type="text" id="account-firstname" name="firstname" class="form-input" value="{{.User.Name}}" required autocomplete="given-name">
              </div>
              <div class="form-group">
                <label class="form-label" for="account-lastname">Nom</label>
                <input type="text" id="account-lastname" name="lastname" class="form-input" value="{{.User.Surname}}" required autocomplete="family-name">
              </div>
            </div>
            <div class="form-group u-mb-4">
              <label class="form-label" for="account-email">Email</label>
              <input type="email" id="account-email" name="email" class="form-input" value="{{.User.Email}}" required autocomplete="email">
            </div>
            <button type="submit" class="btn btn--primary">Enregistrer les modifications</button>
          </form>

          <hr class="u-max-w-520 u-border-t">

          <h3 class="u-mb-6 u-text-xl">Changer le mot de passe</h3>
          <form class="u-max-w-520" action="/account/password" method="POST" up-submit novalidate>
            <div class="form-group u-mb-4">
              <label class="form-label" for="account-current-password">Mot de passe actuel</label>
              <input type="password" id="account-current-password" name="current_password" class="form-input" required autocomplete="current-password">
            </div>
            <div class="form-group u-mb-4">
              <label class="form-label" for="account-new-password">Nouveau mot de passe</label>
              <input type="password" id="account-new-password" name="new_password" class="form-input" required autocomplete="new-password" minlength="8">
              <span class="form-hint">8 caractères minimum, incluant une majuscule et un chiffre.</span>
            </div>
            <div class="form-group u-mb-6">
              <label class="form-label" for="account-confirm-password">Confirmer le mot de passe</label>
              <input type="password" id="account-confirm-password" name="confirm_password" class="form-input" required autocomplete="new-password" minlength="8">
            </div>
            <button type="submit" class="btn btn--secondary">Mettre à jour le mot de passe</button>
          </form>
        </section>
        {{else if eq .ActiveTab "orders"}}
        <!-- ORDERS TAB -->
        <section>
          <h2 class="u-mb-6 u-text-2xl">Mes commandes</h2>
          {{if .Orders}}
          <div class="table-wrapper">
            <table class="table">
              <thead>
                <tr><th>N° commande</th><th>Date</th><th>Articles</th><th>Total</th><th>Statut</th></tr>
              </thead>
              <tbody>
                {{range .Orders}}
                <tr>
                  <td class="u-fw-semibold"><a href="/order/{{.ID}}" up-follow>#{{.Ref}}</a></td>
                  <td>{{date .CreatedAt}}</td>
                  <td>{{len .Items}}</td>
                  <td class="u-fw-medium">{{money .Total}}</td>
                  <td><span class="badge badge--{{.StatusBadge}}">{{.Status}}</span></td>
                </tr>
                {{end}}
              </tbody>
            </table>
          </div>
          {{else}}
          {{template "empty-state" dict "Title" "Aucune commande" "Text" "Vous n'avez pas encore passé de commande." "ActionURL" "/" "ActionLabel" "Découvrir la boutique"}}
          {{end}}
        </section>
        {{else if eq .ActiveTab "favorites"}}
        <!-- FAVORITES TAB -->
        <section>
          <h2 class="u-mb-6 u-text-2xl">Mes favoris</h2>
          {{if .Favorites}}
          <div class="grid-3">
            {{range .Favorites}}
            {{template "product-card" .}}
            {{end}}
          </div>
          {{else}}
          {{template "empty-state" dict "Title" "Aucun favori" "Text" "Ajoutez des articles à vos favoris pour les retrouver facilement." "ActionURL" "/" "ActionLabel" "Découvrir la boutique"}}
          {{end}}
        </section>
        {{end}}
      </div>
    </div>
  </div>
{{end}}
